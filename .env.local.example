# Fitbit OAuth
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Garmin (Nia profile)
GARMIN_NIA_EMAIL=
GARMIN_NIA_PASSWORD=

# Google OAuth (NextAuth) — create at console.cloud.google.com > APIs > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=          # openssl rand -base64 32

# App URL (used for Fitbit OAuth redirect + NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GCP
GCP_PROJECT_ID=
GCS_BUCKET_NAME=      # e.g. <project-id>-exercise-images
