# Copy this to .env.local and fill in your values

# Anthropic
ANTHROPIC_API_KEY=

# Google Cloud project
GCP_PROJECT_ID=your-project-id

# Cloud Storage bucket for exercise images
GCS_BUCKET_NAME=your-bucket-name

# Google OAuth credentials (from GCP Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# next-auth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Fitbit OAuth app credentials
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# App base URL (update after Cloud Run deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev only: path to a service-account key JSON file
# In Cloud Run this is not needed — the attached service account is used automatically
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Seeding scripts only
PAT_EMAIL=pat@example.com
NIA_EMAIL=nia@example.com
GARMIN_NIA_EMAIL=nia@garmin-account.com
GARMIN_NIA_PASSWORD=
