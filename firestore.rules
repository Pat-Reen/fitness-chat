rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile; writes via server SDK only
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server SDK only

      // User's own workout history
      match /workouts/{workoutId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // server SDK only
      }
    }

    // Exercises and equipment: read-only from client
    match /exercises/{group} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /equipment/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Exercise images: read-only from client
    match /exercise_images/{slug} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Image style: read-only from client
    match /image_style/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
